### File 2: llm.py (The Factory)
This file reads the .env and instantiates the correct LangChain chat model. If you don't have Bedrock permissions yet, this file seamlessly falls back to Gemini.
```python
import os
from dotenv import load_dotenv
from langchain_core.language_models.chat_models import BaseChatModel

load_dotenv()

def get_llm() -> BaseChatModel:
    """
    Factory function to instantiate the LLM based on cloud-agnostic .env configuration.
    """
    provider = os.getenv("LLM_PROVIDER", "gemini").lower()
    
    if provider == "gemini":
        from langchain_google_genai import ChatGoogleGenerativeAI
        return ChatGoogleGenerativeAI(
            model="gemini-1.5-flash", 
            temperature=0.1 # Low temp for deterministic data extraction
        )
        
    elif provider == "bedrock":
        from langchain_aws import ChatBedrock
        return ChatBedrock(
            model_id=os.getenv("BEDROCK_MODEL_ID"),
            region_name=os.getenv("AWS_DEFAULT_REGION"),
            model_kwargs={"temperature": 0.1}
        )
        
    elif provider == "azure":
        from langchain_openai import AzureChatOpenAI
        return AzureChatOpenAI(
            deployment_name=os.getenv("AZURE_DEPLOYMENT_NAME"),
            temperature=0.1
        )
        
    else:
        raise ValueError(f"Unsupported LLM_PROVIDER: {provider}")

```
### File 3: state.py (The FO Brain & Schema)
This is the most critical file. It defines the exact JSON structure we will store in Redis. Notice how it **only** includes the Front Office fields mandated by the BRD (Section 4.5 & 4.7) and leaves out the backend derived metrics.
```python
from typing import TypedDict, Optional, List
from pydantic import BaseModel, Field

# --- 1. Sub-Schemas for specific BRD Scenarios ---

class UnauthorizedDisputeSchema(BaseModel):
    """Schema for Scenario 1 & 2: CNP Fraud & Unauthorized Transactions"""
    card_in_possession: Optional[bool] = Field(None, description="Does the customer still have their physical card?")
    shared_details: Optional[bool] = Field(None, description="Did the customer share their PIN or card details with anyone?")
    recognize_merchant: Optional[bool] = Field(None, description="Does the customer recognize the merchant name at all?")

class GoodsNotReceivedSchema(BaseModel):
    """Schema for Scenario 3: Non-Fraud Goods/Services Not Received"""
    expected_delivery_date: Optional[str] = Field(None, description="The date the item was promised to arrive (YYYY-MM-DD)")
    merchant_contacted: Optional[bool] = Field(None, description="Has the customer attempted to contact the merchant?")
    merchant_response: Optional[str] = Field(None, description="Summary of what the merchant said when contacted")
    partial_received: Optional[bool] = Field(None, description="Did they receive part of the order?")

# --- 2. The Master State Schema ---

class FOAgentState(TypedDict):
    """
    The master state object managed by LangGraph and stored in Redis.
    """
    # System Tracking
    session_id: str
    intake_assertion_timestamp: str # Critical for Reg E/Z clocks
    
    # Conversation History
    chat_history: List[dict] 
    
    # Core BRD Data Points (Universal)
    customer_statement: Optional[str] # The raw text claim
    dispute_type: Optional[str] # "unauthorized" or "goods_not_received"
    linked_transaction_ids: List[str] # The specific transactions being disputed
    disputed_amount: Optional[float] # The total value being disputed
    
    # Scenario-Specific Data (These populate based on dispute_type)
    unauthorized_details: Optional[UnauthorizedDisputeSchema]
    gnr_details: Optional[GoodsNotReceivedSchema]
    
    # Graph Control Flags
    intent_locked: bool # Becomes True when Triage is complete
    ready_for_handoff: bool # Becomes True when all required fields are filled

```
