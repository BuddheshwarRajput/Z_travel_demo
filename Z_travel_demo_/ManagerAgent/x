```python
import json
from langgraph.graph import StateGraph, END
from langchain_core.messages import ToolMessage, AIMessage
from state import FOAgentState
from llm import get_llm
from tools import update_dispute_state
from prompts import fo_intake_prompt

llm = get_llm()
llm_with_tools = llm.bind_tools([update_dispute_state])

def triage_and_text_gathering(state: FOAgentState):
    """Phase 1: Gathers text facts."""
    state_as_string = str(state.get("extracted_data", {}))
    formatted_prompt = fo_intake_prompt.format_messages(
        current_state=state_as_string,
        chat_history=state.get("chat_history", [])
    )
    
    response = llm_with_tools.invoke(formatted_prompt)
    messages_to_add = [response]
    
    if response.tool_calls:
        current_data = state.get("extracted_data", {})
        for tool_call in response.tool_calls:
            if tool_call["name"] == "update_dispute_state":
                current_data.update(tool_call["args"])
                tool_msg = ToolMessage(
                    content="State updated successfully.",
                    tool_call_id=tool_call["id"],
                    name=tool_call["name"]
                )
                messages_to_add.append(tool_msg)
        return {"chat_history": messages_to_add, "extracted_data": current_data}

    return {"chat_history": messages_to_add}

def ask_for_evidence(state: FOAgentState):
    """Transition Node: Prompts the user for documents."""
    msg = AIMessage(content="You've done the right things. To support your claim, please upload any of the documents below (Order confirmation, tracking, etc.). Type the file path to upload, or type 'skip'.")
    return {"chat_history": [msg], "ready_for_evidence": True}

def process_evidence(state: FOAgentState):
    """Phase 2: Mocks the Vision API processing of the uploaded documents."""
    uploads = state.get("uploaded_documents", [])
    msg = AIMessage(content=f"Thank you. I have received and checked your {len(uploads)} document(s).")
    return {"chat_history": [msg], "evidence_processed": True}

def skip_warning(state: FOAgentState):
    """Triggered if the user types 'skip'."""
    warning = AIMessage(content="Just a heads up: without uploading evidence, your dispute is much more likely to be declined. Are you sure you want to skip? (yes/no)")
    return {"chat_history": [warning], "skip_warned": True}

def handoff_to_back_office(state: FOAgentState):
    """Final step: Saves the extracted data to local JSON."""
    payload = state.get("extracted_data", {})
    payload["session_id"] = "SESSION_" + str(hash(str(payload)))[-6:] 
    payload["evidence_files"] = state.get("uploaded_documents", [])
    payload["skipped_evidence"] = state.get("skipped_upload", False)

    db_filename = "local_disputes_db.json"
    try:
        with open(db_filename, "r") as f:
            db = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        db = []
        
    db.append(payload)
    with open(db_filename, "w") as f:
        json.dump(db, f, indent=4)
        
    final_msg = AIMessage(content="Done. I have logged your case and routed it to our investigations team. We'll be in touch shortly.")
    return {"chat_history": [final_msg], "is_complete": True}

# --- Routing Logic ---

def route_from_text_phase(state: FOAgentState):
    data = state.get("extracted_data", {})
    # 1. If text data is complete, move to Phase 2 (Evidence)
    if data.get("dispute_type") and data.get("disputed_amount"):
        return "ask_for_evidence"
    # 2. If tool was just called, loop back to ask next question
    last_message = state["chat_history"][-1]
    if getattr(last_message, "type", "") == "tool":
        return "triage_and_text_gathering"
    # 3. Otherwise, pause and wait for user text
    return END

def route_from_evidence_prompt(state: FOAgentState):
    # Pauses the graph so the user can upload files or skip
    return END

def route_evidence_input(state: FOAgentState):
    """Evaluates what the user did during the evidence phase."""
    skipped = state.get("skipped_upload", False)
    warned = state.get("skip_warned", False)
    uploads = state.get("uploaded_documents", [])
    
    if len(uploads) > 0:
        return "process_evidence"
    elif skipped and not warned:
        return "skip_warning"
    elif skipped and warned:
        return "handoff"
    return END

# --- Build the Graph ---
workflow = StateGraph(FOAgentState)

workflow.add_node("text_phase", triage_and_text_gathering)
workflow.add_node("ask_for_evidence", ask_for_evidence)
workflow.add_node("process_evidence", process_evidence)
workflow.add_node("skip_warning", skip_warning)
workflow.add_node("handoff", handoff_to_back_office)

workflow.set_entry_point("text_phase")

# Text Phase Loop
workflow.add_conditional_edges("text_phase", route_from_text_phase, {
    "triage_and_text_gathering": "text_phase",
    "ask_for_evidence": "ask_for_evidence",
    END: END
})

# Move from asking for evidence to pausing for user input
workflow.add_edge("ask_for_evidence", END)

# After process_evidence, always go to handoff
workflow.add_edge("process_evidence", "handoff")

# Skip warning logic
workflow.add_edge("skip_warning", END)

workflow.add_edge("handoff", END)
fo_agent = workflow.compile()

