from pydantic import BaseModel, Field
from typing import Optional

class ChatRequest(BaseModel):
    """The strict payload expected from the UI on every POST request."""
    session_id: str = Field(..., description="Unique identifier for the user's chat session.")
    message: Optional[str] = Field(None, description="The text message from the user.")
    document_path: Optional[str] = Field(None, description="The file path of the uploaded document, if any.")

class ChatResponse(BaseModel):
