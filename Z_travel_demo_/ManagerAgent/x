```python
import uuid
from langgraph.checkpoint.memory import MemorySaver
from graph import workflow

memory = MemorySaver()
fo_agent = workflow.compile(checkpointer=memory)

def run_terminal():
    print("=======================================================")
    print(" 🏦 Smart Agent Assist - Terminal Intake Simulation    ")
    print("=======================================================")
    print(" - Model: AWS Bedrock")
    print(" - Features: Two-Phase Flow (Text -> Evidence)")
    print(" - Type 'exit' to stop.")
    print("=======================================================\n")

    session_id = str(uuid.uuid4())
    config = {"configurable": {"thread_id": session_id}}
    
    # Initialize state tracking variables
    in_evidence_phase = False
    skip_warned = False
    uploaded_docs = []

    while True:
        # Prompt changes based on which phase we are in
        if in_evidence_phase:
            user_text = input("\n📎 Upload file (type filename, 'skip', or 'yes/no' if warned): ")
        else:
            user_text = input("\n👤 You: ")
        
        if user_text.lower() in ['exit', 'quit']:
            break
        if not user_text.strip():
            continue

        # Format input based on the active phase
        if in_evidence_phase:
            if user_text.lower() == 'skip':
                user_input = {"skipped_upload": True}
            elif user_text.lower() in ['yes', 'y'] and skip_warned:
                # User confirmed they want to skip despite the warning
                user_input = {"skipped_upload": True}
            elif user_text.lower() in ['no', 'n'] and skip_warned:
                # User changed their mind after warning
                print("🤖 Ethan: Okay, please provide a file name then.")
                continue
            else:
                # Simulate adding a document (respecting the 3 max rule)
                if len(uploaded_docs) < 3:
                    uploaded_docs.append(user_text)
                    user_input = {"uploaded_documents": uploaded_docs, "skipped_upload": False}
                else:
                    print("⚠️ Maximum of 3 documents allowed.")
                    continue
        else:
            # Standard conversational text input
            user_input = {"chat_history": [{"role": "user", "content": user_text}]}

        try:
            final_state = fo_agent.invoke(user_input, config=config)
            
            # Print the bot's response
            bot_responses = [msg for msg in final_state.get("chat_history", []) if getattr(msg, "type", "") == "ai"]
            if bot_responses:
                print(f"🤖 Ethan: {bot_responses[-1].content}")

            # Check if we transitioned to the evidence phase
            if final_state.get("ready_for_evidence") and not final_state.get("evidence_processed"):
                in_evidence_phase = True
                
            # Check if the skip warning was triggered
            if final_state.get("skip_warned"):
                skip_warned = True

            # If the graph executed the process_evidence node, we need to manually push it to handoff
            if final_state.get("evidence_processed") and not final_state.get("is_complete"):
                 final_state = fo_agent.invoke({"chat_history": []}, config=config) # push to handoff
                 bot_responses = [msg for msg in final_state.get("chat_history", []) if getattr(msg, "type", "") == "ai"]
                 if bot_responses:
                     print(f"🤖 Ethan: {bot_responses[-1].content}")

            # Check if the flow is entirely finished
            if final_state.get("is_complete"):
                print("\n✅ [SYSTEM] Case closed and routed to local_disputes_db.json!")
                break
                
        except Exception as e:
            print(f"\n❌ [ERROR] Something went wrong: {e}")
            break

if __name__ == "__main__":
    run_terminal()

```
