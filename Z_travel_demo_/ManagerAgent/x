import os
import boto3
from dotenv import load_dotenv
from langchain_aws import ChatBedrock

load_dotenv()

def get_llm():
    """
    Instantiates the AWS Bedrock LLM using the custom enterprise token.
    """
    provider = os.getenv("LLM_PROVIDER", "bedrock").lower()
    
    if provider == "bedrock":
        # 1. Grab your custom token from the .env file
        bedrock_token = os.getenv("AWS_BEARER_TOKEN_BEDROCK")
        
        if not bedrock_token:
            raise ValueError("AWS_BEARER_TOKEN_BEDROCK is missing from the .env file!")

        # 2. Force Boto3 to use your token.
        # Enterprise Bedrock gateways typically map the API key to the aws_access_key_id.
        boto3_client = boto3.client(
            "bedrock-runtime",
            region_name=os.getenv("AWS_DEFAULT_REGION", "us-east-1"),
            aws_access_key_id=bedrock_token,
            aws_secret_access_key="dummy_secret", # boto3 requires this if an access key is provided
            aws_session_token=bedrock_token       # Passed as fallback for certain gateways
        )
        
        # 3. Pass our custom, authenticated client into LangChain
        return ChatBedrock(
            client=boto3_client,
            model_id=os.getenv("BEDROCK_MODEL_ID"),
            model_kwargs={"temperature": 0.1} # Low temp so it doesn't hallucinate
        )
    else:
        raise ValueError(f"Unsupported LLM_PROVIDER: {provider}")

