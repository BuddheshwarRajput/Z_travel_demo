import os
import json
import requests
from typing import Dict, Any
from dotenv import load_dotenv
from fastmcp import FastMCP

# load_dotenv()

API_URL = "https://ivr-uat.payflex.com/api/Employee/FetchEmployeeAccounts"
PARTNER_ID = "458BF15F-D45D-4385-B3EA-9903C76CF411"
CONTENT_TYPE = "application/json"  # FIX: Added '='
PORT = 8002                        # FIX: Added '='
HOST = "0.0.0.0"

if not API_URL:
    raise ValueError("CRITICAL: 'AUTH_API_URL' environment variable is missing!")

mcp = FastMCP("Inspira Auth Server")

def _tool_result(response: Dict[str, Any], state_update: Dict[str, Any] = None) -> str:
    """FIX: Re-added the helper to wrap the return payload for LangGraph."""
    result = {"response": response, "state_update": state_update or {}}
    return json.dumps(result)

@mcp.tool()
def verify_customer_identity(ssn_or_member_id: str, zip_code: str, date_of_birth: str) -> str:
    """Verifies a customer using EITHER their SSN or Member ID, plus Zip and DOB."""
    
    headers = {
        "PartnerId": PARTNER_ID,
        "Content-Type": CONTENT_TYPE
    }

    # SUCCESS: You successfully made this dynamic!
    payload = {
        "lastFourSsnOrMemberId": ssn_or_member_id,
        "zipCode": zip_code,
        "dateOfBirth": date_of_birth
    }

    try:
        response = requests.post(API_URL, json=payload, headers=headers, timeout=10)
        
        if response.status_code == 200:
            data = response.json()
            accounts = data.get("accounts", [])
            
            # FIX: Safe check in case the accounts list is empty
            if not accounts:
                return _tool_result(
                    response={"status": "failure", "message": "Identity verified, but no active accounts found."},
                    state_update={"authentication_status": False}
                )
                
            account_info = accounts[0]
            
            return _tool_result(
                response={
                    "status": "success",
                    "member_id": payload["lastFourSsnOrMemberId"],
                    "employer_name": account_info.get("employerName"),
                    "available_balance": account_info.get("availableBalance")
                },
                # FIX: Properly segregating state updates for LangGraph
                state_update={
                    "authentication_status": True,
                    "member_id": payload["lastFourSsnOrMemberId"]
                }
            )
        else:
            return _tool_result(
                response={"status": "failure", "message": f"Identity verification failed. HTTP {response.status_code}"},
                state_update={"authentication_status": False}
            )
            
    except Exception as e:
        return _tool_result(
            response={"status": "error", "message": f"API Connection Error: {str(e)}"},
            state_update={"authentication_status": False}
        )

if __name__ == "__main__":
    print("Starting Inspira MCP Server via SSE transport on port 8002...")
    # FIX: Using the native fastmcp transport to avoid the 404/400 bug
    mcp.run(transport="sse", host=HOST, port=PORT)
