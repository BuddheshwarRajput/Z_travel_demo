### File 5: graph.py (The Core LangGraph Orchestration)
This file stitches our two-phase architecture together. Notice the specific check_evidence_gate routing logic that handles your 3-document limit and the "Skip" warning.
```python
from langgraph.graph import StateGraph, END
from state import FOAgentState
from llm import get_llm
from tools import update_dispute_state, flag_document_discrepancy

# Instantiate the agnostic LLM
llm = get_llm()
llm_with_tools = llm.bind_tools([update_dispute_state])

# --- Node Definitions ---

def triage_and_text_gathering(state: FOAgentState):
    """Phase 1: Gathers text facts based on the active schema."""
    # LLM processes chat_history and calls update_dispute_state if facts are found
    response = llm_with_tools.invoke(state["chat_history"])
    return {"chat_history": [response]}

def evidence_extraction(state: FOAgentState):
    """Phase 2: Multimodal extraction from uploaded documents (Max 3)."""
    # Logic to pass up to 3 base64 images to the Vision LLM
    # LLM extracts data, calls flag_document_discrepancy if needed
    return {"evidence_processed": True}

def skip_warning(state: FOAgentState):
    """Triggered if the user skips document upload."""
    warning_msg = (
        "Just a heads up: without uploading evidence like a receipt or tracking number, "
        "your dispute is much more likely to be declined. Are you sure you want to skip?"
    )
    return {"chat_history": [{"role": "assistant", "content": warning_msg}], "skip_warned": True}

def handoff_to_back_office(state: FOAgentState):
    """Final step: Compiles the JSON and hits the BO REST API."""
    print(f"Handoff Payload Ready: {state['extracted_data']}")
    return {"is_complete": True}

# --- Edge Routing Logic ---

def route_from_text_phase(state: FOAgentState):
    """Checks if the text schema is full and routes to evidence."""
    # If all required text fields are filled, move to Evidence phase
    if state.get("ready_for_evidence"):
        return "evidence_gate"
    return "triage_and_text_gathering"

def check_evidence_gate(state: FOAgentState):
    """Handles the 3-document limit and the skip logic."""
    uploads = state.get("uploaded_documents", [])
    skipped = state.get("skipped_upload", False)
    warned = state.get("skip_warned", False)
    
    if len(uploads) > 0 and len(uploads) <= 3:
        return "evidence_extraction"
    elif skipped and not warned:
        return "skip_warning"
    elif skipped and warned:
        return "handoff_to_back_office" # User insisted on skipping
    
    return "handoff_to_back_office" # Default fallback

# --- Build the Graph ---

workflow = StateGraph(FOAgentState)

workflow.add_node("text_phase", triage_and_text_gathering)
workflow.add_node("evidence_phase", evidence_extraction)
workflow.add_node("warning_node", skip_warning)
workflow.add_node("handoff", handoff_to_back_office)

workflow.set_entry_point("text_phase")

# Continuous text loop until ready for documents
workflow.add_conditional_edges("text_phase", route_from_text_phase, {
    "triage_and_text_gathering": "text_phase",
    "evidence_gate": "evidence_phase"
})

# Evidence routing (handles uploads, limits, and skip warnings)
workflow.add_conditional_edges("evidence_phase", check_evidence_gate, {
    "evidence_extraction": "evidence_phase",
    "skip_warning": "warning_node",
    "handoff_to_back_office": "handoff"
})

workflow.add_edge("warning_node", "handoff") # After warning, go to handoff if they confirm
workflow.add_edge("handoff", END)

fo_agent = workflow.compile()

```
