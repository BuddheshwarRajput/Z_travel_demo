```
### 2. The Complete database.py File
Replace your database.py file with this fully fleshed-out version. It handles the connection, creates a default table if it doesn't exist, safely injects the JSON payload, and closes the connection.
```python
import os
import json
from abc import ABC, abstractmethod
import psycopg2
from psycopg2.extras import Json

# 1. The Abstract Base Class
class DataRepository(ABC):
    @abstractmethod
    def save_case(self, payload: dict):
        pass

# 2. The JSON Implementation (Local Testing)
class JSONRepository(DataRepository):
    def __init__(self, file_path="local_disputes_db.json"):
        self.file_path = file_path

    def save_case(self, payload: dict):
        if os.path.exists(self.file_path):
            try:
                with open(self.file_path, "r") as f:
                    db_data = json.load(f)
                    if not isinstance(db_data, list):
                        db_data = []
            except json.JSONDecodeError:
                db_data = []
        else:
            db_data = []

        db_data.append(payload)

        with open(self.file_path, "w") as f:
            json.dump(db_data, f, indent=4)
        
        print(f"[SYSTEM LOG] Case saved successfully to {self.file_path}")


# 3. The Fully Wired Postgres Implementation
class PostgresRepository(DataRepository):
    def __init__(self):
        # Grabs connection details from the .env file
        self.host = os.getenv("DB_HOST", "localhost")
        self.port = os.getenv("DB_PORT", "5432")
        self.dbname = os.getenv("DB_NAME", "postgres")
        self.user = os.getenv("DB_USER", "postgres")
        self.password = os.getenv("DB_PASSWORD", "postgres")

    def save_case(self, payload: dict):
        conn = None
        cursor = None
        try:
            # 1. Establish the connection to the database
            conn = psycopg2.connect(
                host=self.host,
                port=self.port,
                dbname=self.dbname,
                user=self.user,
                password=self.password
            )
            cursor = conn.cursor()

            # 2. Create a flexible table if the DB team hasn't made one yet
            # JSONB is highly optimized in Postgres for storing dynamic AI payloads
            cursor.execute("""
                CREATE TABLE IF NOT EXISTS ai_intake_cases (
                    id SERIAL PRIMARY KEY,
                    session_id VARCHAR(255),
                    dispute_type VARCHAR(100),
                    payload JSONB,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                );
            """)

            # 3. Extract top-level keys for easy querying, keep the rest in JSONB
            session_id = payload.get("session_id", "UNKNOWN_SESSION")
            dispute_type = payload.get("dispute_type", "UNKNOWN_TYPE")

            # 4. Insert the record safely to prevent SQL Injection
            insert_query = """
                INSERT INTO ai_intake_cases (session_id, dispute_type, payload) 
                VALUES (%s, %s, %s);
            """
            cursor.execute(insert_query, (session_id, dispute_type, Json(payload)))

            # 5. Commit the transaction
            conn.commit()
            print(f"[SYSTEM LOG] Case {session_id} successfully saved to Postgres DB.")

        except Exception as e:
            print(f"[ERROR] Failed to save case to Postgres: {e}")
            if conn:
                conn.rollback() # Undo the transaction if something crashes
        finally:
            # 6. Always close the connection to prevent memory leaks
            if cursor:
                cursor.close()
            if conn:
                conn.close()


# 4. The Master Switch
def get_repository() -> DataRepository:
    """Reads the .env file and returns the correct database adapter."""
    db_type = os.getenv("DB_TYPE", "JSON").upper()
    
    if db_type == "POSTGRES":
        print("[SYSTEM LOG] Initializing Postgres Connection...")
        return PostgresRepository()
    else:
        print("[SYSTEM LOG] Initializing Local JSON Storage...")
        return JSONRepository()

```
