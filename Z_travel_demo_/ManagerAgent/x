Create this new file in your directory. This replaces main.py. It initializes LangGraph's local memory, sets up the Bedrock session, and runs a clean CLI interface.
```python
import uuid
from langgraph.checkpoint.memory import MemorySaver
from graph import workflow

# 1. Compile the graph WITH memory so it remembers the conversation history
memory = MemorySaver()
fo_agent = workflow.compile(checkpointer=memory)

def run_terminal():
    print("=======================================================")
    print(" 🏦 Smart Agent Assist - Terminal Intake Simulation    ")
    print("=======================================================")
    print(" - Model: AWS Bedrock")
    print(" - Target: JSON Local Database")
    print(" - Type 'exit' or 'quit' at any time to stop.")
    print("=======================================================\n")

    # Generate a unique session ID for this specific run
    session_id = str(uuid.uuid4())
    config = {"configurable": {"thread_id": session_id}}

    while True:
        # 1. Get input from the terminal
        user_text = input("\n👤 You: ")
        
        if user_text.lower() in ['exit', 'quit']:
            print("Ending simulation...")
            break
            
        if not user_text.strip():
            continue

        # 2. Format it for our LangGraph State
        user_input = {"chat_history": [{"role": "user", "content": user_text}]}

        try:
            # 3. Run the agent
            final_state = fo_agent.invoke(user_input, config=config)
            
            # 4. Extract the bot's latest text response
            bot_responses = [
                msg for msg in final_state["chat_history"] 
                if getattr(msg, "type", "") == "ai" or msg.get("role") == "assistant"
            ]
            
            if bot_responses:
                latest_reply = bot_responses[-1]
                reply_text = getattr(latest_reply, "content", latest_reply.get("content", ""))
                print(f"🤖 Ethan: {reply_text}")
            
            # 5. Check if the graph reached the handoff node
            if final_state.get("is_complete"):
                print("\n✅ [SYSTEM] Case closed and routed to local_disputes_db.json!")
                break
                
        except Exception as e:
            print(f"\n❌ [ERROR] Something went wrong: {e}")
            break

if __name__ == "__main__":
    run_terminal()

```
