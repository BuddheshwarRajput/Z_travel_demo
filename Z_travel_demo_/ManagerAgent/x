import os
from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from langchain_core.messages import HumanMessage
from dotenv import load_dotenv

# Import our Custom Modules
from schema import ChatRequest, ChatResponse
from graph import fo_agent

# Load environment variables
load_dotenv()

app = FastAPI(title="Bank Front Office AI Agent", version="1.0.0")

# Setup CORS (Allow All for Testing Phase)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], # The Bouncer lets everyone in
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/health")
async def health_check():
    """DevOps uses this to verify the container hasn't crashed."""
    return {"status": "healthy", "database_mode": os.getenv("DB_TYPE", "JSON")}

@app.post("/api/chat", response_model=ChatResponse)
async def chat_endpoint(request: ChatRequest):
    """The main entry point for the frontend UI."""
    
    # 1. Tell LangGraph which user's memory to look up
    thread_config = {"configurable": {"thread_id": request.session_id}}
    
    # 2. Package the user's input
    user_input = request.document_path if request.document_path else request.message
    
    if not user_input:
        raise HTTPException(status_code=400, detail="Must provide either a message or a document_path.")

    input_message = HumanMessage(content=user_input)

    try:
        # 3. Run the Agent
        print(f"[INFO] Processing chat for session: {request.session_id}")
        result = fo_agent.invoke({"chat_history": [input_message]}, config=thread_config)
        
        # 4. Extract the data to send back to the UI
        chat_history = result.get("chat_history", [])
        last_ai_message = chat_history[-1].content if chat_history else ""
        
        extracted_data = result.get("extracted_data", {})
        current_intent = extracted_data.get("dispute_type")
        is_complete = result.get("is_complete", False)
        
        # 5. Return the strict schema contract
        return ChatResponse(
            status="success",
            ai_response=last_ai_message,
            is_complete=is_complete,
            current_intent=current_intent
        )
        
    except Exception as e:
        print(f"[ERROR] Failed to process chat: {str(e)}")
        raise HTTPException(status_code=500, detail="Internal AI Engine Error")

# To run locally: uvicorn main:app --host 0.0.0.0 --port 8000 --reload

```
