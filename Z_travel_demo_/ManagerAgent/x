import json
from langgraph.graph import StateGraph, END
from langchain_core.messages import ToolMessage
from state import FOAgentState
from llm import get_llm
from tools import update_dispute_state
from prompts import fo_intake_prompt

# Instantiate LLM and bind our strict data extraction tool
llm = get_llm()
llm_with_tools = llm.bind_tools([update_dispute_state])

def triage_and_text_gathering(state: FOAgentState):
    """Phase 1: Gathers text facts and executes tool calls to update state."""
    
    # 1. Inject current state into our anti-hallucination prompt
    state_as_string = str(state.get("extracted_data", {}))
    formatted_prompt = fo_intake_prompt.format_messages(
        current_state=state_as_string,
        chat_history=state.get("chat_history", [])
    )
    
    # 2. Get LLM response
    response = llm_with_tools.invoke(formatted_prompt)
    messages_to_add = [response]
    
    # 3. TOOL EXECUTION LOGIC (The Missing Piece)
    # If the LLM decided it found a fact (e.g. amount = $750), we must save it.
    if response.tool_calls:
        current_data = state.get("extracted_data", {})
        
        for tool_call in response.tool_calls:
            if tool_call["name"] == "update_dispute_state":
                # Update our JSON state with the new facts
                current_data.update(tool_call["args"])
                
                # We must give the LLM a 'ToolMessage' back so it knows it succeeded
                tool_msg = ToolMessage(
                    content="State updated successfully.",
                    tool_call_id=tool_call["id"],
                    name=tool_call["name"]
                )
                messages_to_add.append(tool_msg)
                
        return {"chat_history": messages_to_add, "extracted_data": current_data}

    # If it was just a normal conversational response
    return {"chat_history": messages_to_add}

def handoff_to_back_office(state: FOAgentState):
    """Final step: Saves the extracted data to a local JSON file (Our Mock DB)."""
    payload = state.get("extracted_data", {})
    
    # Add a session ID to track it
    payload["session_id"] = "SESSION_" + str(hash(str(payload)))[-6:] 

    db_filename = "local_disputes_db.json"
    
    # Read existing DB, append new case, save back to file
    try:
        with open(db_filename, "r") as f:
            db = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        db = []
        
    db.append(payload)
    
    with open(db_filename, "w") as f:
        json.dump(db, f, indent=4)
        
    print(f"CASE SAVED TO JSON DATABASE: {payload}")
    
    # Send a final goodbye to the UI
    final_msg = {"role": "assistant", "content": "Done. I have logged your case and routed it to our team. We will be in touch shortly."}
    return {"chat_history": [final_msg], "is_complete": True}

def route_from_text_phase(state: FOAgentState):
    """If all required fields are filled, trigger Handoff."""
    data = state.get("extracted_data", {})
    # Simple check: if we have a dispute_type and an amount, we are done
    if data.get("dispute_type") and data.get("disputed_amount"):
        return "handoff"
    return "triage_and_text_gathering"

# --- Build the Graph ---
workflow = StateGraph(FOAgentState)

workflow.add_node("text_phase", triage_and_text_gathering)
workflow.add_node("handoff", handoff_to_back_office)

workflow.set_entry_point("text_phase")

workflow.add_conditional_edges("text_phase", route_from_text_phase, {
    "triage_and_text_gathering": "text_phase",
    "handoff": "handoff"
})

workflow.add_edge("handoff", END)

fo_agent = workflow.compile()

