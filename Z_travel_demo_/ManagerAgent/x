from langchain_core.tools import tool
from state import FOAgentState

@tool
def update_dispute_state(
    dispute_type: str = None,
    disputed_amount: float = None,
    merchant_contacted: bool = None,
    merchant_response: str = None,
    expected_delivery_date: str = None
):
    """
    Use this tool to update the customer's intake record in the database.
    Only pass values that you have explicitly confirmed from the user's chat.
    """
    # In a LangGraph node, the tool call arguments will be merged into the state.
    # Pydantic will automatically validate that 'disputed_amount' is a number, etc.
    return {
        "dispute_type": dispute_type,
        "disputed_amount": disputed_amount,
        "merchant_contacted": merchant_contacted,
        "merchant_response": merchant_response,
        "expected_delivery_date": expected_delivery_date
    }

@tool
def flag_document_discrepancy(reason: str):
    """
    Use this tool ONLY during the Evidence Phase if the amount extracted 
    from the uploaded document does not match the amount the customer stated.
    """
    return {"document_mismatch_flag": True, "mismatch_reason": reason}

