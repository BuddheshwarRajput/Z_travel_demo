        is_evidence_phase = current_state.get("ready_for_evidence", False)
        
        # Dynamically change the terminal prompt based on the phase
        if is_evidence_phase:
            user_text = input("\n📎 Upload file (type path, 'skip', or 'yes/no'): ")
        else:
