    if dtype == "unauthorized":
        if data.get("block_card_consent") is not None and data.get("card_in_possession") is not None:
            is_ready = True
            
    # 2. Cancellation Validation
    elif dtype == "cancelled_booking_charged":
        if data.get("disputed_amount") and data.get("has_cancellation_proof") is not None:
            is_ready = True
            
    # 3. Goods Not Received Validation
    elif dtype == "goods_not_received":
        if data.get("disputed_amount") and data.get("expected_delivery_date"):
            is_ready = True

    if is_ready and not state.get("ready_for_evidence"):
        return "ask_for_evidence"
        
    last_message = state["chat_history"][-1]
    is_tool_obj = getattr(last_message, "type", "") == "tool"
    is_tool_dict = isinstance(last_message, dict) and last_message.get("type") == "tool"

    if is_tool_obj or is_tool_dict: 
        return "triage_and_text_gathering"

    return END

